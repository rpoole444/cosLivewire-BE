NODE_ENV=development
PORT=3000
FRONTEND_BASE_URL=http://localhost:3001
API_BASE_URL=http://localhost:3000

# Required production infrastructure
DATABASE_URL=
REDIS_URL=
SESSION_SECRET=

# Amazon S3 (the AWS SDK also reads AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY)
AWS_REGION=
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=

# Google identity login (identity scopes only)
GOOGLE_LOGIN_CLIENT_ID=
GOOGLE_LOGIN_CLIENT_SECRET=
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Calendar import (calendar.readonly scope)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/imports/google/callback

# Optional behavior
ANALYTICS_SALT=
BCRYPT_SALT_ROUNDS=10
DEFAULT_TRIAL_DAYS=30
MOONDOG_PROMOTER_ID=
